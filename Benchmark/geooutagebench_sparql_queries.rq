WHERE {
  ?ntl a goo:NTLImage ;
       goo:representsCounty gokg:LeeCountyFL ;
       goo:acquisitionDateTime ?imageDate ;
       goo:hasOutageMap ?map .
  ?map a goo:OutageMap .
  FILTER(
    ?imageDate >= "2022-09-23T00:00:00Z"^^xsd:dateTime &&
    ?imageDate <  "2022-10-08T00:00:00Z"^^xsd:dateTime
  )
}
