# Template Family: event_window_outage_threshold
# Question: Which storm events in Florida started before same-county EAGLE-I records that later exceeded 50,000 outages on the same day?
# Question Template: Which {EVENT_TYPE} in {STATE} started before same-county {OUTAGE_RECORD_SOURCE} records that later exceeded {OUTAGE_THRESHOLD} on {TEMPORAL_ALIGNMENT}?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatiotemporal, semantic
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT DISTINCT ?event ?county ?eventType ?eventStart ?record ?recordDate ?numOutages
WHERE {
  ?event a goo:StormEventRecord ;
         goo:occurredInState gokg:FloridaState ;
         goo:occurredInCounty ?county ;
         goo:stormEventType ?eventType ;
         goo:eventStartTime ?eventStart .
  ?record a goo:CustomerOutageRecord ;
          goo:representsCounty ?county ;
          goo:recordDateTime ?recordDate ;
          goo:numberOfOutages ?numOutages .
  FILTER (?numOutages > 50000)
  FILTER (?eventStart <= ?recordDate)
  FILTER (SUBSTR(STR(?eventStart), 1, 10) = SUBSTR(STR(?recordDate), 1, 10))
}
ORDER BY ?county ?eventStart DESC(?numOutages)
LIMIT 10

