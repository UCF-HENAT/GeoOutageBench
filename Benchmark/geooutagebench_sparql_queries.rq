PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?ntl ?rec ?date ?num
WHERE {
  ?rec a goo:CustomerOutageRecord ;
       goo:representsCounty gokg:LeeCountyFL ;
       goo:recordDateTime ?date ;
       goo:numberOfOutages ?num .
  ?ntl a goo:NTLImage ;
       goo:representsCounty gokg:LeeCountyFL ;
       goo:acquisitionDateTime ?imageDate .
  FILTER (SUBSTR(STR(?date), 1, 10) = SUBSTR(STR(?imageDate), 1, 10))
  FILTER(
    ?date >= "2022-09-28T00:00:00Z"^^xsd:dateTime &&
    ?date <  "2022-09-29T00:00:00Z"^^xsd:dateTime
  )
}
