PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?ntl ?rec ?date ?num
WHERE {
  ?rec a goo:CustomerOutageRecord ;
       goo:representsCounty gokg:LeeCountyFL ;
       goo:recordDateTime ?date ;
       goo:numberOfOutages ?num .
  ?ntl a goo:NTLImage ;
       goo:representsCounty gokg:LeeCountyFL ;
       goo:acquisitionDateTime ?imageDate .
  FILTER(
    ?date >= "2022-09-28T04:00:00Z"^^xsd:dateTime &&
    ?date <  "2022-09-29T04:00:00Z"^^xsd:dateTime
  )
  FILTER(
    ?imageDate >= "2022-09-28T04:00:00Z"^^xsd:dateTime &&
    ?imageDate <  "2022-09-29T04:00:00Z"^^xsd:dateTime
  )
}
ORDER BY ?date
LIMIT 10
