# Query 19
# QID: 1000015
# Interpretation ID: Q1000015_I0
# Interpretation Type: original source query
# Template ID: T004
# Template Family: multimodal_correspondence
# Question: During the Hurricane Ian landfall date, which nighttime-light scenes line up with outage snapshots for the southwest Florida county centered on Fort Myers?
# Question Template: During {EVENT_WINDOW}, which {IMAGE_TYPE} scenes line up with outage snapshots for {PLACE_DESCRIPTOR}?
# Label: Primary interpretation: Lee County outage snapshots and NTL scenes on Hurricane Ian landfall date
# Ambiguity Dimensions: spatiotemporal, temporal, semantic
# Rationale: Aligns the edited question to Lee County outage records and NTL scenes on the September 28, 2022 Hurricane Ian landfall date.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?ntl ?rec ?date ?num
WHERE {
  ?rec a goo:CustomerOutageRecord ;
       goo:representsCounty gokg:LeeCountyFL ;
       goo:recordDateTime ?date ;
       goo:numberOfOutages ?num .
  ?ntl a goo:NTLImage ;
       goo:representsCounty gokg:LeeCountyFL ;
       goo:acquisitionDateTime ?imageDate .
  FILTER (SUBSTR(STR(?date), 1, 10) = SUBSTR(STR(?imageDate), 1, 10))
  FILTER(
    ?date >= "2022-09-28T00:00:00Z"^^xsd:dateTime &&
    ?date <  "2022-09-29T00:00:00Z"^^xsd:dateTime
  )
}
ORDER BY ?date
LIMIT 10
