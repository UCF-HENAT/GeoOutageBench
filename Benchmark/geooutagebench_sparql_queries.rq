# Query 17
# QID: 1000014
# Interpretation ID: Q1000014_I0
# Interpretation Type: original source query
# Template ID: T005
# Template Family: event_window_outage_threshold
# Question: During the Hurricane Ian disruption period, which outage records for the southwest Florida county centered on Fort Myers were above 100?
# Question Template: During {EVENT_WINDOW}, which {OUTAGE_RECORD_TYPE} for {PLACE_DESCRIPTOR} were above {OUTAGE_THRESHOLD}?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatiotemporal, semantic
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?rec ?date ?num
WHERE {
  ?rec a goo:CustomerOutageRecord ;
       goo:representsCounty gokg:LeeCountyFL ;
       goo:recordDateTime ?date ;
       goo:numberOfOutages ?num .
  FILTER (?num > 100)
  FILTER(
    ?date >= "2022-08-28T00:00:00Z"^^xsd:dateTime &&
    ?date <  "2022-10-28T00:00:00Z"^^xsd:dateTime
  )
}
ORDER BY ?date
LIMIT 10

