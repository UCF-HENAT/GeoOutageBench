# Query 6
# QID: 1000003
# Interpretation ID: Q1000003_I1
# Interpretation Type: template-based interpretation
# Template ID: T002
# Template Family: temporal_interval_filter
# Question: Which nighttime-light images cover the Orlando-area county in 2025?
# Question Template: Which {IMAGE_TYPE} images cover the {PLACE_DESCRIPTOR} in {TEMPORAL_WINDOW}?
# Label: Spatial interpretation: Orlando area as metro-adjacent counties
# Ambiguity Dimensions: spatial
# Rationale: The phrase "Orlando-area county" can mean Orange County alone or a small set of Orlando metro counties.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?ntl ?date ?locator
WHERE {
  VALUES ?county { gokg:OrangeCountyFL gokg:SeminoleCountyFL gokg:OsceolaCountyFL gokg:LakeCountyFL }
  ?ntl a goo:NTLImage ;
       goo:acquisitionDateTime ?date ;
       goo:representsCounty ?county ;
       goo:sourceDownloadUrl ?locator .
  FILTER (?date >= "2025-01-01T00:00:00Z"^^xsd:dateTime && ?date < "2026-01-01T00:00:00Z"^^xsd:dateTime)
}
ORDER BY ?date
LIMIT 10

