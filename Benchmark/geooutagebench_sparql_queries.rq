# Query 64
# QID: 1000044
# Interpretation ID: Q1000044_I0
# Interpretation Type: primary interpretation
# Template ID: T005
# Template Family: event_window_outage_threshold
# Question: On the day of the Joplin tornado, how many tornado records occurred in or within the general area of the Joplin county, and what were their EF ratings and death counts?
# Question Template: On {EVENT_DAY}, how many {EVENT_TYPE} records occurred in or within {SPATIAL_WINDOW} of {JURISDICTION_INSTANCE}, and what were their ratings and death counts?
# Label: Primary interpretation: Jasper County general-area tornado records on the Joplin tornado day
# Ambiguity Dimensions: spatiotemporal, semantic
# Rationale: Uses the Moore tornado template while resolving the Joplin county wording to the county most directly associated with Joplin, Missouri.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX geosparql:  <http://www.opengis.net/ont/geosparql#>
PREFIX geof:       <http://www.opengis.net/def/function/geosparql/>
PREFIX units:      <http://www.opengis.net/def/uom/OGC/1.0/>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?eventCount ?event ?efScale ?deathsDirect
WHERE {
  {
    SELECT (COUNT(DISTINCT ?event) AS ?eventCount)
    WHERE {
      gokg:JasperCountyMO geosparql:hasGeometry ?countyGeom .
      ?countyGeom geosparql:asWKT ?countyWKT .
      ?event a goo:TornadoEventRecord ;
             goo:eventStartTime ?start ;
             goo:eventEndTime ?end ;
             goo:torFScale ?efScale ;
             goo:deathsDirect ?deathsDirect ;
             goo:lat ?eventLat ;
             goo:lon ?eventLon .
      BIND(STRDT(CONCAT("POINT(", STR(?eventLon), " ", STR(?eventLat), ")"), geosparql:wktLiteral) AS ?eventPoint)
      FILTER (?start < "2011-05-23T00:00:00"^^xsd:dateTime && ?end >= "2011-05-22T00:00:00"^^xsd:dateTime)
      FILTER (geof:distance(?eventPoint, ?countyWKT, units:metre) <= 10000)
    }
  }
  gokg:JasperCountyMO geosparql:hasGeometry ?countyGeom .
  ?countyGeom geosparql:asWKT ?countyWKT .
  ?event a goo:TornadoEventRecord ;
         goo:eventStartTime ?start ;
         goo:eventEndTime ?end ;
         goo:torFScale ?efScale ;
         goo:deathsDirect ?deathsDirect ;
         goo:lat ?eventLat ;
         goo:lon ?eventLon .
  BIND(STRDT(CONCAT("POINT(", STR(?eventLon), " ", STR(?eventLat), ")"), geosparql:wktLiteral) AS ?eventPoint)
  FILTER (?start < "2011-05-23T00:00:00"^^xsd:dateTime && ?end >= "2011-05-22T00:00:00"^^xsd:dateTime)
  FILTER (geof:distance(?eventPoint, ?countyWKT, units:metre) <= 10000)
}
ORDER BY ?event

# ------------------------------------------------------------------------------

# Query 65
# QID: 1000044
# Interpretation ID: Q1000044_I1
# Interpretation Type: spatial-semantic interpretation
# Template ID: T005
# Template Family: event_window_outage_threshold
# Question: On the day of the Joplin tornado, how many tornado records occurred in or within the general area of the Joplin county, and what were their EF ratings and death counts?
# Question Template: On {EVENT_DAY}, how many {EVENT_TYPE} records occurred in or within {SPATIAL_WINDOW} of {JURISDICTION_INSTANCE}, and what were their ratings and death counts?
# Label: Spatial-semantic interpretation: broader Joplin area using Jasper and Newton counties
# Ambiguity Dimensions: spatial, semantic
# Rationale: Joplin spans the Jasper-Newton county area, so this interpretation broadens the county scope while preserving the same tornado-day and 10 km general-area rule.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX geosparql:  <http://www.opengis.net/ont/geosparql#>
PREFIX geof:       <http://www.opengis.net/def/function/geosparql/>
PREFIX units:      <http://www.opengis.net/def/uom/OGC/1.0/>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT DISTINCT ?eventCount ?event ?efScale ?deathsDirect
WHERE {
  {
    SELECT (COUNT(DISTINCT ?event) AS ?eventCount)
    WHERE {
      VALUES ?county { gokg:JasperCountyMO gokg:NewtonCountyMO }
      ?county geosparql:hasGeometry ?countyGeom .
      ?countyGeom geosparql:asWKT ?countyWKT .
      ?event a goo:TornadoEventRecord ;
             goo:eventStartTime ?start ;
             goo:eventEndTime ?end ;
             goo:torFScale ?efScale ;
             goo:deathsDirect ?deathsDirect ;
             goo:lat ?eventLat ;
             goo:lon ?eventLon .
      BIND(STRDT(CONCAT("POINT(", STR(?eventLon), " ", STR(?eventLat), ")"), geosparql:wktLiteral) AS ?eventPoint)
      FILTER (?start < "2011-05-23T00:00:00"^^xsd:dateTime && ?end >= "2011-05-22T00:00:00"^^xsd:dateTime)
      FILTER (geof:distance(?eventPoint, ?countyWKT, units:metre) <= 10000)
    }
  }
  VALUES ?county { gokg:JasperCountyMO gokg:NewtonCountyMO }
  ?county geosparql:hasGeometry ?countyGeom .
  ?countyGeom geosparql:asWKT ?countyWKT .
  ?event a goo:TornadoEventRecord ;
         goo:eventStartTime ?start ;
         goo:eventEndTime ?end ;
         goo:torFScale ?efScale ;
         goo:deathsDirect ?deathsDirect ;
         goo:lat ?eventLat ;
         goo:lon ?eventLon .
  BIND(STRDT(CONCAT("POINT(", STR(?eventLon), " ", STR(?eventLat), ")"), geosparql:wktLiteral) AS ?eventPoint)
  FILTER (?start < "2011-05-23T00:00:00"^^xsd:dateTime && ?end >= "2011-05-22T00:00:00"^^xsd:dateTime)
  FILTER (geof:distance(?eventPoint, ?countyWKT, units:metre) <= 10000)
}
ORDER BY ?event

