# Query 3
# QID: 1000002
# Interpretation ID: Q1000002_I0
# Interpretation Type: original source query
# Template ID: T002
# Template Family: temporal_interval_filter
# Question: Which customer outage records were recorded in the calendar year after 2021?
# Question Template: Which {OUTAGE_RECORD_TYPE} were recorded in the {TEMPORAL_WINDOW}?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: temporal
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?rec ?recordDate ?numOutages
WHERE {
  ?rec a goo:CustomerOutageRecord ;
       goo:recordDateTime ?recordDate ;
       goo:numberOfOutages ?numOutages .
  FILTER (?recordDate >= "2022-01-01T00:00:00Z"^^xsd:dateTime && ?recordDate < "2023-01-01T00:00:00Z"^^xsd:dateTime)
}
ORDER BY ?recordDate
LIMIT 10

