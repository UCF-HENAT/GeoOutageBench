# Query 25
# QID: 1000017
# Interpretation ID: Q1000017_I0
# Interpretation Type: original source query
# Template ID: T001
# Template Family: outage_ranking_by_jurisdiction
# Question: For each county, what is the maximum number of customer outages recorded in the year Hurricane Irma occurred in?
# Question Template: For each {JURISDICTION_TYPE}, what is the maximum number of {OUTAGE_METRIC} recorded in {EVENT_YEAR_DESCRIPTOR}?
# Label: Primary interpretation: maximum county outages during calendar year 2017
# Ambiguity Dimensions: spatiotemporal, temporal
# Rationale: Adds the 2017 temporal filter required by the edited Hurricane Irma wording while preserving the per-county maximum outage aggregation.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?county (MAX(?num) AS ?maxOutages)
WHERE {
  ?rec a goo:CustomerOutageRecord ;
       goo:representsCounty ?county ;
       goo:recordDateTime ?date ;
       goo:numberOfOutages ?num .
  FILTER(
    ?date >= "2017-01-01T00:00:00Z"^^xsd:dateTime &&
    ?date <  "2018-01-01T00:00:00Z"^^xsd:dateTime
  )
}
GROUP BY ?county
ORDER BY DESC(?maxOutages)
LIMIT 10
# ------------------------------------------------------------------------------

# Query 26
# QID: 1000018
# Interpretation ID: Q1000018_I0
# Interpretation Type: original source query
# Template ID: T011
# Template Family: svi_aggregation_by_jurisdiction
# Question: For each second-level administrative division in the U.S., what is their average social vulnerability index?
# Question Template: For each {ADMIN_DIVISION_SCOPE}, what is their average {SVI_METRIC}?
# Label: Primary interpretation: average SVI overall score for each U.S. county
# Ambiguity Dimensions: spatial, semantic
# Rationale: Replaces the previous multimodal outage-map interpretation with the edited SVI aggregation question over county-level SVI records.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?adminDivision (AVG(?sviScore) AS ?averageSviOverallScore)
WHERE {
  ?adminDivision a goo:County .
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?adminDivision ;
             goo:sviOverallScore ?sviScore .
}
GROUP BY ?adminDivision
ORDER BY ?adminDivision
LIMIT 10
# ------------------------------------------------------------------------------

# Query 27
# QID: 1000019
# Interpretation ID: Q1000019_I0
# Interpretation Type: original source query
# Template ID: T001
# Template Family: outage_ranking_by_jurisdiction
# Question: On what date and time did each jurisdiction reach its maximum recorded number of customer outages?
# Question Template: On what date and time did each {JURISDICTION_TYPE} reach its maximum recorded number of {OUTAGE_METRIC}?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatiotemporal
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?county ?maxOutages ?dateOfMax
WHERE {
  {
    SELECT ?county (MAX(?num) AS ?maxOutages)
    WHERE {
      ?rec a goo:CustomerOutageRecord ;
           goo:representsCounty ?county ;
           goo:numberOfOutages ?num .
    }
    GROUP BY ?county
  }
  ?rec a goo:CustomerOutageRecord ;
       goo:representsCounty ?county ;
       goo:numberOfOutages ?maxOutages ;
       goo:recordDateTime ?dateOfMax .
}
ORDER BY DESC(?maxOutages)
LIMIT 10

