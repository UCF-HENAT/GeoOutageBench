# Query 52
# QID: 1000034
# Interpretation ID: Q1000034_I0
# Interpretation Type: original source query
# Template ID: T002
# Template Family: temporal_interval_filter
# Question: Which Atlantic and Pacific hurricanes lasted more than three days and reached maximum sustained winds of an extremely powerful cyclone?
# Question Template: Which {BASIN_SET} hurricanes lasted more than {DURATION_THRESHOLD} and reached maximum sustained winds of {INTENSITY_DESCRIPTOR}?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatiotemporal, semantic
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX schema: <http://schema.org/>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?cyclone ?name ?start ?end ?maxSustainedWindSpeed
WHERE {
  VALUES ?basin { "ATL"^^xsd:string "EPAC"^^xsd:string "CPAC"^^xsd:string }
  BIND(160 AS ?extremelyPowerfulWindThreshold)
  ?cyclone a goo:HurricaneEventRecord ;
           schema:name ?name ;
           goo:basin ?basin ;
           goo:eventStartTime ?start ;
           goo:eventEndTime ?end ;
           goo:maxSustainedWindSpeed ?maxSustainedWindSpeed .
  FILTER (?maxSustainedWindSpeed >= ?extremelyPowerfulWindThreshold)
  FILTER ((?end - ?start) > "P3D"^^xsd:dayTimeDuration)
}
ORDER BY DESC(?maxSustainedWindSpeed) ?start
LIMIT 10

# ------------------------------------------------------------------------------

# Query 53
# QID: 1000034
# Interpretation ID: Q1000034_I1
# Interpretation Type: template-based interpretation
# Template ID: T002
# Template Family: temporal_interval_filter
# Question: Which Atlantic and Pacific hurricanes lasted more than three days and reached maximum sustained winds of an extremely powerful cyclone?
# Question Template: Which {BASIN_SET} hurricanes lasted more than {DURATION_THRESHOLD} and reached maximum sustained winds of {INTENSITY_DESCRIPTOR}?
# Label: Semantic interpretation: extremely powerful as Category-5-style threshold in alternate wind units
# Ambiguity Dimensions: semantic
# Rationale: The phrase "extremely powerful cyclone" is semantic; this variant makes the intensity threshold less strict.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX schema: <http://schema.org/>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?cyclone ?name ?start ?end ?maxSustainedWindSpeed
WHERE {
  VALUES ?basin { "ATL"^^xsd:string "EPAC"^^xsd:string "CPAC"^^xsd:string }
  BIND(137 AS ?extremelyPowerfulWindThreshold)
  ?cyclone a goo:HurricaneEventRecord ;
           schema:name ?name ;
           goo:basin ?basin ;
           goo:eventStartTime ?start ;
           goo:eventEndTime ?end ;
           goo:maxSustainedWindSpeed ?maxSustainedWindSpeed .
