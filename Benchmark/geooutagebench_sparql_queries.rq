    FILTER (?start < "2022-09-30T00:00:00+00:00"^^xsd:dateTime && ?end >= "2022-09-27T00:00:00+00:00"^^xsd:dateTime)
    FILTER (?trackDate >= "2022-09-27T00:00:00+00:00"^^xsd:dateTime && ?trackDate < "2022-09-30T00:00:00+00:00"^^xsd:dateTime)
