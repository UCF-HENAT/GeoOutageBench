# GeoOutageBench SPARQL queries
# Generated from GeoResilience/Benchmark/geooutagebench_questions.json
# Questions: 48
# SPARQL interpretations: 72
# sparql_interpretations[0] preserves the original source query; later entries are template-based ambiguity variants.

# Query 1
# QID: 1000000
# Interpretation ID: Q1000000_I0
# Interpretation Type: original source query
# Template ID: T001
# Template Family: outage_ranking_by_jurisdiction
# Question: Which counties have the highest number of customer outages reported at one time?
# Question Template: Which {JURISDICTION_TYPE} have the highest number of {OUTAGE_METRIC}?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatial
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?county ?maxOutages
WHERE {
  {
    SELECT ?county (MAX(?num) AS ?maxOutages)
    WHERE {
      ?rec a goo:CustomerOutageRecord ;
           goo:representsCounty ?county ;
           goo:numberOfOutages ?num .
    }
    GROUP BY ?county
  }
}
ORDER BY DESC(?maxOutages)
LIMIT 10

