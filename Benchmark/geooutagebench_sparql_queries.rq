# Query 54
# QID: 1000035
# Interpretation ID: Q1000035_I0
# Interpretation Type: thresholded interpretation
# Template ID: T007
# Template Family: storm_event_svi_county_threshold
# Question: Which counties in the state bordering Alabama and Georgia had an SVI overall score of at least 0.8 in the year before 2023 and a number of storm events recorded that same year?
# Question Template: Which counties in {STATE_DESCRIPTOR} had {SVI_DESCRIPTOR} in {RELATIVE_YEAR_DESCRIPTOR} and a number of {EVENT_TYPE} recorded that same year?
# Label: KG interpretation with storm-event count threshold
# Ambiguity Dimensions: spatial, temporal, semantic, spatiotemporal
# Rationale: Preserves the question text while operationalizing 'a number of storm events' as COUNT(DISTINCT ?event) >= 8.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?county ?sviRecord ?sviScore ?stormEventCount
WHERE {
  ?state a goo:State ;
         goo:neighboringStates gokg:AlabamaState ;
         goo:neighboringStates gokg:GeorgiaState .
  ?county a goo:County ;
          goo:locatedInState ?state .
  BIND((2023 - 1) AS ?targetYear)
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?county ;
             goo:sviYear ?targetYear ;
             goo:sviOverallScore ?sviScore .
  FILTER (?sviScore >= 0.8)
  {
    SELECT ?county ?state (COUNT(DISTINCT ?event) AS ?stormEventCount)
    WHERE {
      BIND((2023 - 1) AS ?eventYear)
      ?event a goo:StormEventRecord ;
             goo:occurredInState ?state ;
             goo:occurredInCounty ?county ;
             goo:eventStartTime ?eventStart .
      FILTER (YEAR(?eventStart) = ?eventYear)
    }
    GROUP BY ?county ?state
  }
  FILTER (?stormEventCount >= 8)
}
ORDER BY DESC(?sviScore) DESC(?stormEventCount)

# ------------------------------------------------------------------------------

# Query 55
# QID: 1000036
# Interpretation ID: Q1000036_I0
# Interpretation Type: original source query
# Template ID: T008
# Template Family: longitudinal_svi_population_change
# Question: For the administrative divisions in the U.S. with the highest Social Vulnerability Indexes, what was their SVI at the start of the new millennium, then one decade later, then one decade after that, and what was their population increase in those two decades, and their poverty levels?
# Question Template: For the {ADMIN_DIVISION_SCOPE} with {RANKING_DESCRIPTOR}, what was their {SVI_METRIC} at {YEAR_A_DESCRIPTOR}, then {YEAR_B_DESCRIPTOR}, then {YEAR_C_DESCRIPTOR}, and what was their {POPULATION_CHANGE_METRIC} in {POPULATION_CHANGE_WINDOW}, and their {POVERTY_METRIC}?
# Label: Primary KG interpretation: counties ranked by 2020 SVI with poverty rates
# Ambiguity Dimensions: spatial, temporal, semantic
# Rationale: Operationalizes the natural-language longitudinal SVI question using county-level CDC SVI records available in the KG, including poverty rates for each requested SVI year.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?adminDivision ?sviRecord2000 ?svi2000 ?povertyRate2000 ?sviRecord2010 ?svi2010 ?povertyRate2010 ?sviRecord2020 ?svi2020 ?povertyRate2020 ?populationIncrease2000To2020
WHERE {
  ?adminDivision a goo:County .
  ?sviRecord2000 a goo:SVIRecord ;
                 goo:representsCounty ?adminDivision ;
                 goo:sviYear 2000 ;
                 goo:sviOverallScore ?svi2000 ;
                 goo:povertyRate ?povertyRate2000 ;
                 goo:totalPopulation ?population2000 .
  ?sviRecord2010 a goo:SVIRecord ;
                 goo:representsCounty ?adminDivision ;
                 goo:sviYear 2010 ;
                 goo:sviOverallScore ?svi2010 ;
                 goo:povertyRate ?povertyRate2010 .
  ?sviRecord2020 a goo:SVIRecord ;
                 goo:representsCounty ?adminDivision ;
                 goo:sviYear 2020 ;
                 goo:sviOverallScore ?svi2020 ;
                 goo:povertyRate ?povertyRate2020 ;
                 goo:totalPopulation ?population2020 .
  BIND((xsd:integer(?population2020) - xsd:integer(?population2000)) AS ?populationIncrease2000To2020)
}
ORDER BY DESC(?svi2020) ?adminDivision
LIMIT 10

