# Query 37
# QID: 1000027
# Interpretation ID: Q1000027_I0
# Interpretation Type: original source query
# Template ID: T005
# Template Family: event_window_outage_threshold
# Question: On the day of the Moore tornado, how many tornado records occurred in or within the general area of Cleveland County, Oklahoma, and what were their EF ratings and injury counts?
# Question Template: On {EVENT_DAY}, how many {EVENT_TYPE} records occurred in or within {SPATIAL_WINDOW} of {JURISDICTION_INSTANCE}, and what were their ratings and injury counts?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatiotemporal
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX geosparql: <http://www.opengis.net/ont/geosparql#>
PREFIX geof:       <http://www.opengis.net/def/function/geosparql/>
PREFIX units:      <http://www.opengis.net/def/uom/OGC/1.0/>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?eventCount ?event ?efScale ?injuriesDirect
WHERE {
  {
    SELECT (COUNT(DISTINCT ?event) AS ?eventCount)
    WHERE {
      gokg:ClevelandCountyOK geosparql:hasGeometry ?countyGeom .
      ?countyGeom geosparql:asWKT ?countyWKT .
      ?event a goo:TornadoEventRecord ;
             goo:eventStartTime ?start ;
             goo:eventEndTime ?end ;
             goo:torFScale ?efScale ;
             goo:injuriesDirect ?injuriesDirect ;
             goo:lat ?eventLat ;
             goo:lon ?eventLon .
      BIND(STRDT(CONCAT("POINT(", STR(?eventLon), " ", STR(?eventLat), ")"), geosparql:wktLiteral) AS ?eventPoint)
      FILTER (?start < "2013-05-21T00:00:00"^^xsd:dateTime && ?end >= "2013-05-20T00:00:00"^^xsd:dateTime)
      FILTER (geof:distance(?eventPoint, ?countyWKT, units:metre) <= 10000)
    }
  }
  gokg:ClevelandCountyOK geosparql:hasGeometry ?countyGeom .
  ?countyGeom geosparql:asWKT ?countyWKT .
  ?event a goo:TornadoEventRecord ;
         goo:eventStartTime ?start ;
         goo:eventEndTime ?end ;
         goo:torFScale ?efScale ;
         goo:injuriesDirect ?injuriesDirect ;
         goo:lat ?eventLat ;
         goo:lon ?eventLon .
  BIND(STRDT(CONCAT("POINT(", STR(?eventLon), " ", STR(?eventLat), ")"), geosparql:wktLiteral) AS ?eventPoint)
  FILTER (?start < "2013-05-21T00:00:00"^^xsd:dateTime && ?end >= "2013-05-20T00:00:00"^^xsd:dateTime)
  FILTER (geof:distance(?eventPoint, ?countyWKT, units:metre) <= 10000)
}
ORDER BY ?event

