# Query 32
# QID: 1000024
# Interpretation ID: Q1000024_I0
# Interpretation Type: optimized source-derived query
# Template ID: T004
# Template Family: multimodal_correspondence
# Question: For the central-Florida county where the largest city is named Clermont, what derived severity maps are associated with the VIIRS-captured scene for the month of March in 2024?
# Question Template: For {PLACE_DESCRIPTOR}, what derived {MAP_TYPE} are associated with the {SENSOR_TYPE}-captured {IMAGE_TYPE} scene for {TEMPORAL_WINDOW}?
# Label: Optimized KG interpretation with March 2024 image-date filter
# Ambiguity Dimensions: spatiotemporal, semantic
# Rationale: Resolves the Clermont largest-city descriptor to Lake County, filters VIIRS NTL scenes to March 2024 by acquisition date, and returns only derived outage maps.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT DISTINCT ?map
WHERE {
  ?ntl a goo:NTLImage ;
       goo:fromSensor gokg:sensor.VIIRS ;
       goo:representsCounty gokg:LakeCountyFL ;
       goo:acquisitionDateTime ?imageDate ;
       goo:hasOutageMap ?map .
  ?map a goo:OutageMap .
  FILTER (?imageDate >= "2024-03-01T00:00:00Z"^^xsd:dateTime && ?imageDate < "2024-04-01T00:00:00Z"^^xsd:dateTime)
}
ORDER BY ?map
LIMIT 10

# ------------------------------------------------------------------------------

# Query 33
# QID: 1000025
# Interpretation ID: Q1000025_I0
# Interpretation Type: original source query
# Template ID: T002
# Template Family: temporal_interval_filter
# Question: How many tropical cyclones were active on the date 6 October 2024 in the Atlantic basin, and what were their names and maximum sustained wind speeds?
# Question Template: How many {CYCLONE_TYPE} were active on {DATE} in {BASIN}, and what were their names and maximum sustained wind speeds?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: temporal
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX schema: <http://schema.org/>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?activeCycloneCount ?cyclone ?name ?maxSustainedWindSpeed
WHERE {
  {
    SELECT (COUNT(DISTINCT ?cyclone) AS ?activeCycloneCount)
    WHERE {
      ?cyclone a goo:HurricaneEventRecord  ;
               goo:basin "ATL"^^xsd:string ;
               goo:eventStartTime ?start ;
               goo:eventEndTime ?end .
      FILTER (
        ?start < "2024-10-07T00:00:00+00:00"^^xsd:dateTime &&
        ?end >= "2024-10-06T00:00:00+00:00"^^xsd:dateTime
      )
    }
  }
  ?cyclone a goo:HurricaneEventRecord ;
           schema:name ?name ;
           goo:maxSustainedWindSpeed ?maxSustainedWindSpeed ;
           goo:basin "ATL"^^xsd:string ;
           goo:eventStartTime ?start ;
           goo:eventEndTime ?end .
  FILTER (
    ?start < "2024-10-07T00:00:00+00:00"^^xsd:dateTime &&
    ?end >= "2024-10-06T00:00:00+00:00"^^xsd:dateTime
  )
}
ORDER BY ?name

# ------------------------------------------------------------------------------

# Query 34
# QID: 1000026
# Interpretation ID: Q1000026_I0
# Interpretation Type: original source query
# Template ID: T005
# Template Family: event_window_outage_threshold
# Question: On Ian's Florida landfall day, what was the peak outage count in the southwest Florida county centered on Fort Myers, and were any hurricanes active within the general area of the county that day, and if so what were their names?
# Question Template: On {CYCLONE_EVENT}'s {REFERENCE_DATE}, what was the peak outage count in {PLACE_DESCRIPTOR}, and were any hurricanes active within {SPATIAL_WINDOW} that day?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatiotemporal
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX schema:     <http://schema.org/>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?maxOutages ?hasNearbyHurricane (GROUP_CONCAT(DISTINCT STR(?nearbyHurricaneName); separator=", ") AS ?hurricaneNames)
WHERE {
  {
    SELECT (MAX(?num) AS ?maxOutages)
    WHERE {
      ?record a goo:CustomerOutageRecord ;
              goo:representsCounty gokg:LeeCountyFL ;
              goo:recordDateTime ?recordDate ;
              goo:numberOfOutages ?num .
      FILTER (SUBSTR(STR(?recordDate), 1, 10) = "2022-09-28")
    }
  }
  {
    SELECT (COUNT(DISTINCT ?nearbyCyclone) > 0 AS ?hasNearbyHurricane)
    WHERE {
      gokg:LeeCountyFL goo:lat ?countyLat ;
                       goo:lon ?countyLon .
      ?nearbyCyclone a goo:HurricaneEventRecord ;
                     schema:name ?nearbyHurricaneName ;
                     goo:eventStartTime ?start ;
                     goo:eventEndTime ?end ;
                     goo:hasTrackRecord ?track .
      ?track a goo:HurricaneTrackRecord ;
             goo:recordDateTime ?trackDate ;
             goo:lat ?trackLat ;
             goo:lon ?trackLon .
      FILTER (?start < "2022-09-29T00:00:00+00:00"^^xsd:dateTime && ?end >= "2022-09-28T00:00:00+00:00"^^xsd:dateTime)
      FILTER (SUBSTR(STR(?trackDate), 1, 10) = "2022-09-28")
      FILTER (
        ABS(xsd:decimal(?trackLat) - xsd:decimal(?countyLat)) <= 5 &&
        ABS(xsd:decimal(?trackLon) - xsd:decimal(?countyLon)) <= 5
      )
    }
  }
  OPTIONAL {
    gokg:LeeCountyFL goo:lat ?countyLat ;
                     goo:lon ?countyLon .
    ?nearbyCyclone a goo:HurricaneEventRecord ;
                   schema:name ?nearbyHurricaneName ;
                   goo:eventStartTime ?start ;
                   goo:eventEndTime ?end ;
                   goo:hasTrackRecord ?track .
    ?track a goo:HurricaneTrackRecord ;
           goo:recordDateTime ?trackDate ;
           goo:lat ?trackLat ;
           goo:lon ?trackLon .
    FILTER (?start < "2022-09-29T00:00:00+00:00"^^xsd:dateTime && ?end >= "2022-09-28T00:00:00+00:00"^^xsd:dateTime)
    FILTER (SUBSTR(STR(?trackDate), 1, 10) = "2022-09-28")
    FILTER (
      ABS(xsd:decimal(?trackLat) - xsd:decimal(?countyLat)) <= 5 &&
      ABS(xsd:decimal(?trackLon) - xsd:decimal(?countyLon)) <= 5
    )
  }
}
GROUP BY ?maxOutages ?hasNearbyHurricane

# ------------------------------------------------------------------------------

# Query 35
# QID: 1000026
# Interpretation ID: Q1000026_I1
# Interpretation Type: template-based interpretation
# Template ID: T005
# Template Family: event_window_outage_threshold
# Question: On Ian's Florida landfall day, what was the peak outage count in the southwest Florida county centered on Fort Myers, and were any hurricanes active within the general area of the county that day, and if so what were their names?
# Question Template: On {CYCLONE_EVENT}'s {REFERENCE_DATE}, what was the peak outage count in {PLACE_DESCRIPTOR}, and were any hurricanes active within {SPATIAL_WINDOW} that day?
# Label: Spatial interpretation: tighter general-area window around Lee County
# Ambiguity Dimensions: spatial
# Rationale: The phrase "within the general area" can be operationalized with a smaller latitude/longitude window.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX schema:     <http://schema.org/>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?maxOutages ?hasNearbyHurricane (GROUP_CONCAT(DISTINCT STR(?nearbyHurricaneName); separator=", ") AS ?hurricaneNames)
WHERE {
  {
    SELECT (MAX(?num) AS ?maxOutages)
    WHERE {
      ?record a goo:CustomerOutageRecord ;
              goo:representsCounty gokg:LeeCountyFL ;
              goo:recordDateTime ?recordDate ;
              goo:numberOfOutages ?num .
      FILTER (SUBSTR(STR(?recordDate), 1, 10) = "2022-09-28")
    }
  }
  {
    SELECT (COUNT(DISTINCT ?nearbyCyclone) > 0 AS ?hasNearbyHurricane)
    WHERE {
      gokg:LeeCountyFL goo:lat ?countyLat ;
                       goo:lon ?countyLon .
      ?nearbyCyclone a goo:HurricaneEventRecord ;
                     schema:name ?nearbyHurricaneName ;
                     goo:eventStartTime ?start ;
                     goo:eventEndTime ?end ;
                     goo:hasTrackRecord ?track .
      ?track a goo:HurricaneTrackRecord ;
             goo:recordDateTime ?trackDate ;
             goo:lat ?trackLat ;
             goo:lon ?trackLon .
      FILTER (?start < "2022-09-29T00:00:00+00:00"^^xsd:dateTime && ?end >= "2022-09-28T00:00:00+00:00"^^xsd:dateTime)
      FILTER (SUBSTR(STR(?trackDate), 1, 10) = "2022-09-28")
      FILTER (
        ABS(xsd:decimal(?trackLat) - xsd:decimal(?countyLat)) <= 2 &&
        ABS(xsd:decimal(?trackLon) - xsd:decimal(?countyLon)) <= 2
      )
    }
  }
  OPTIONAL {
    gokg:LeeCountyFL goo:lat ?countyLat ;
                     goo:lon ?countyLon .
    ?nearbyCyclone a goo:HurricaneEventRecord ;
                   schema:name ?nearbyHurricaneName ;
                   goo:eventStartTime ?start ;
                   goo:eventEndTime ?end ;
                   goo:hasTrackRecord ?track .
    ?track a goo:HurricaneTrackRecord ;
           goo:recordDateTime ?trackDate ;
           goo:lat ?trackLat ;
           goo:lon ?trackLon .
    FILTER (?start < "2022-09-29T00:00:00+00:00"^^xsd:dateTime && ?end >= "2022-09-28T00:00:00+00:00"^^xsd:dateTime)
    FILTER (SUBSTR(STR(?trackDate), 1, 10) = "2022-09-28")
    FILTER (
      ABS(xsd:decimal(?trackLat) - xsd:decimal(?countyLat)) <= 2 &&
      ABS(xsd:decimal(?trackLon) - xsd:decimal(?countyLon)) <= 5
    )
  }
}
GROUP BY ?maxOutages ?hasNearbyHurricane

