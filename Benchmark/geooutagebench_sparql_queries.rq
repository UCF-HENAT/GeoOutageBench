# Label: Primary KG interpretation: state hurricane landfall ranking with average county-level SVI
# Ambiguity Dimensions: spatial, temporal, semantic
# Rationale: Operationalizes the state-level hurricane landfall ranking using GeoSPARQL containment of hurricane track points and joins the ranked states to county-level SVI records aggregated by state.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX geosparql:  <http://www.opengis.net/ont/geosparql#>
PREFIX geof:       <http://www.opengis.net/def/function/geosparql/>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?state ?hurricaneLandfallCount ?averageCountySviOverallScore
WHERE {
  {
    SELECT ?state (COUNT(DISTINCT ?cyclone) AS ?hurricaneLandfallCount)
    WHERE {
      ?state a goo:State ;
             geosparql:hasGeometry ?stateGeom .
      ?stateGeom geosparql:asWKT ?stateWKT .
      ?cyclone a goo:HurricaneEventRecord ;
               goo:hasTrackRecord ?track .
      ?track a goo:HurricaneTrackRecord ;
             goo:status "HU"^^xsd:string ;
             goo:lat ?trackLat ;
             goo:lon ?trackLon .
      BIND(STRDT(CONCAT("POINT(", STR(?trackLon), " ", STR(?trackLat), ")"), geosparql:wktLiteral) AS ?trackPoint)
      FILTER (geof:sfWithin(?trackPoint, ?stateWKT))
    }
    GROUP BY ?state
  }
  OPTIONAL {
    SELECT ?state (AVG(?sviScore) AS ?averageCountySviOverallScore)
    WHERE {
      ?county a goo:County ;
              goo:locatedInState ?state .
      ?sviRecord a goo:SVIRecord ;
                 goo:representsCounty ?county ;
                 goo:sviOverallScore ?sviScore .
    }
    GROUP BY ?state
  }
}
ORDER BY DESC(?hurricaneLandfallCount) DESC(?averageCountySviOverallScore)
LIMIT 10

# ------------------------------------------------------------------------------

# Query 57
# QID: 1000038
# Interpretation ID: Q1000038_I0
# Interpretation Type: original source query
# Template ID: T005
# Template Family: event_window_outage_threshold
# Question: On the day of the Moore tornado, how many tornado records occurred within 50 km of Cleveland County, Oklahoma, and what were their EF ratings and injury counts?
# Question Template: On {EVENT_DAY}, how many {EVENT_TYPE} records occurred in or within {SPATIAL_WINDOW} of {JURISDICTION_INSTANCE}, and what were their ratings and injury counts?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatiotemporal
# Rationale: Preserves the original SPARQL query exactly as supplied for this GeoOutageBench entry.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX geosparql:  <http://www.opengis.net/ont/geosparql#>
PREFIX geof:       <http://www.opengis.net/def/function/geosparql/>
PREFIX units:      <http://www.opengis.net/def/uom/OGC/1.0/>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?eventCount ?event ?efScale ?injuriesDirect
WHERE {
  {
    SELECT (COUNT(DISTINCT ?event) AS ?eventCount)
    WHERE {
      gokg:ClevelandCountyOK geosparql:hasGeometry ?countyGeom .
      ?countyGeom geosparql:asWKT ?countyWKT .
      ?event a goo:TornadoEventRecord ;
             goo:eventStartTime ?start ;
             goo:eventEndTime ?end ;
             goo:torFScale ?efScale ;
             goo:injuriesDirect ?injuriesDirect ;
             goo:lat ?eventLat ;
             goo:lon ?eventLon .
      BIND(STRDT(CONCAT("POINT(", STR(?eventLon), " ", STR(?eventLat), ")"), geosparql:wktLiteral) AS ?eventPoint)
      FILTER (?start < "2013-05-21T00:00:00"^^xsd:dateTime && ?end >= "2013-05-20T00:00:00"^^xsd:dateTime)
      FILTER (geof:distance(?eventPoint, ?countyWKT, units:metre) <= 50000)
    }
  }
  gokg:ClevelandCountyOK geosparql:hasGeometry ?countyGeom .
  ?countyGeom geosparql:asWKT ?countyWKT .
  ?event a goo:TornadoEventRecord ;
         goo:eventStartTime ?start ;
         goo:eventEndTime ?end ;
         goo:torFScale ?efScale ;
         goo:injuriesDirect ?injuriesDirect ;
         goo:lat ?eventLat ;
         goo:lon ?eventLon .
  BIND(STRDT(CONCAT("POINT(", STR(?eventLon), " ", STR(?eventLat), ")"), geosparql:wktLiteral) AS ?eventPoint)
  FILTER (?start < "2013-05-21T00:00:00"^^xsd:dateTime && ?end >= "2013-05-20T00:00:00"^^xsd:dateTime)
  FILTER (geof:distance(?eventPoint, ?countyWKT, units:metre) <= 50000)
}
ORDER BY ?event

# ------------------------------------------------------------------------------

# Query 58
# QID: 1000039
# Interpretation ID: Q1000039_I0
# Interpretation Type: original source query
# Template ID: T004
# Template Family: multimodal_correspondence
# Question: Which NTL images and outage-severity maps provide multimodal evidence for Florida county outage records above 250,000 during Hurricane Ian's immediate landfall impact window?
# Question Template: Which {IMAGE_TYPE} images and {MAP_TYPE} provide multimodal evidence for {STATE} county outage records above {OUTAGE_THRESHOLD} during {EVENT_WINDOW}?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatiotemporal, semantic
# Rationale: Preserves the original SPARQL query exactly as supplied for this GeoOutageBench entry.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT DISTINCT ?county ?record ?recordDate ?numOutages ?ntl ?map ?locator
WHERE {
  ?county a goo:County ;
          goo:locatedInState gokg:FloridaState .
  ?record a goo:CustomerOutageRecord ;
          goo:representsCounty ?county ;
          goo:recordDateTime ?recordDate ;
          goo:numberOfOutages ?numOutages .
  ?ntl a goo:NTLImage ;
       goo:representsCounty ?county ;
       goo:acquisitionDateTime ?imageDate ;
       goo:hasOutageMap ?map ;
       goo:sourceDownloadUrl ?locator .
  ?map a goo:OutageMap .
  FILTER (?numOutages > 250000)
  FILTER (?imageDate >= "2022-09-28T00:00:00Z"^^xsd:dateTime && ?imageDate < "2022-10-03T00:00:00Z"^^xsd:dateTime)
  FILTER (?recordDate >= "2022-09-28T00:00:00Z"^^xsd:dateTime && ?recordDate < "2022-10-03T00:00:00Z"^^xsd:dateTime)
}
ORDER BY ?county ?recordDate
LIMIT 10

# ------------------------------------------------------------------------------

# Query 59
# QID: 1000040
# Interpretation ID: Q1000040_I0
# Interpretation Type: rephrased source query
# Template ID: T005
# Template Family: event_window_outage_threshold
# Question: If the county where Hurricane Helene made landfall's outage impact propagated to neighboring counties, which neighboring counties' latest SVI overall scores were substantial and had outage records above 10,000 during the immediate landfall window?
# Question Template: If {FOCAL_PLACE}'s outage impact extended to {SPATIAL_RELATION} during {EVENT_WINDOW}, which counties had {VULNERABILITY_CONDITION} and {OUTAGE_CONDITION}?
# Label: Rephrased KG interpretation for Hurricane Helene landfall county neighbors
# Ambiguity Dimensions: spatial, temporal, semantic, spatiotemporal
# Rationale: Rephrases the scenario to Hurricane Helene's Taylor County, Florida landfall, returns distinct county names only, interprets substantial SVI as >= 0.5 on the latest available SVI record, and filters outage records above 10,000 in the immediate landfall window.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT DISTINCT ?county (STR(?countyLabel) AS ?countyName)
WHERE {
  gokg:TaylorCountyFL goo:neighboringCounties ?county .
  ?county a goo:County ;
          rdfs:label ?countyLabel ;
          goo:locatedInState gokg:FloridaState .
  FILTER (LANGMATCHES(LANG(?countyLabel), "en"))
  {
    SELECT ?county (MAX(?sviYear) AS ?latestSviYear)
    WHERE {
      ?candidateSvi a goo:SVIRecord ;
                    goo:representsCounty ?county ;
                    goo:sviYear ?sviYear .
    }
    GROUP BY ?county
  }
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?county ;
             goo:sviYear ?latestSviYear ;
             goo:sviOverallScore ?sviScore .
  ?record a goo:CustomerOutageRecord ;
          goo:representsCounty ?county ;
          goo:recordDateTime ?recordDate ;
          goo:numberOfOutages ?numOutages .
  FILTER (?sviScore >= 0.5)
  FILTER (?numOutages > 10000)
  FILTER (?recordDate >= "2024-09-26T00:00:00Z"^^xsd:dateTime && ?recordDate < "2024-10-01T00:00:00Z"^^xsd:dateTime)
}
ORDER BY ?countyName

# ------------------------------------------------------------------------------

# Query 60
# QID: 1000041
# Interpretation ID: Q1000041_I0
# Interpretation Type: original source query
# Template ID: T007
# Template Family: storm_event_svi_county_threshold
# Question: Which counties in states neighboring Florida had 2022 SVI housing-and-transportation scores of at least 0.85 and at least five flood-related storm events that same year?
# Question Template: Which counties in {STATE_DESCRIPTOR} had {SVI_DESCRIPTOR} in {RELATIVE_YEAR_DESCRIPTOR} and a number of {EVENT_TYPE} recorded that same year?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatial, temporal, semantic, spatiotemporal
# Rationale: Preserves the original SPARQL query exactly as supplied for this GeoOutageBench entry.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?county ?state ?sviRecord ?housingTransportationScore ?floodEventCount
WHERE {
  ?state a goo:State ;
         goo:neighboringStates gokg:FloridaState .
  ?county a goo:County ;
          goo:locatedInState ?state .
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?county ;
             goo:sviYear 2022 ;
             goo:sviHousingTransportationTheme ?housingTransportationScore .
  FILTER (?housingTransportationScore >= 0.85)
  {
    SELECT ?county ?state (COUNT(DISTINCT ?event) AS ?floodEventCount)
    WHERE {
      ?event a goo:StormEventRecord ;
             goo:occurredInState ?state ;
             goo:occurredInCounty ?county ;
             goo:stormEventType ?eventType ;
             goo:eventStartTime ?eventStart .
      FILTER (YEAR(?eventStart) = 2022)
      FILTER (REGEX(STR(?eventType), "flood", "i"))
    }
    GROUP BY ?county ?state
  }
  FILTER (?floodEventCount >= 5)
}
ORDER BY DESC(?housingTransportationScore) DESC(?floodEventCount) ?county
LIMIT 10

# ------------------------------------------------------------------------------

# Query 61
# QID: 1000042
# Interpretation ID: Q1000042_I0
# Interpretation Type: original source query
# Template ID: T008
# Template Family: longitudinal_svi_population_change
# Question: For Florida counties with the highest 2022 SVI housing-and-transportation scores, what were their SVI overall scores in 2000, 2010, and 2022, their population change from 2000 to 2022, and their 2022 poverty rates?
# Question Template: For the {ADMIN_DIVISION_SCOPE} with {RANKING_DESCRIPTOR}, what was their {SVI_METRIC} at {YEAR_A_DESCRIPTOR}, then {YEAR_B_DESCRIPTOR}, then {YEAR_C_DESCRIPTOR}, and what was their {POPULATION_CHANGE_METRIC} in {POPULATION_CHANGE_WINDOW}, and their {POVERTY_METRIC}?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatial, temporal, semantic
# Rationale: Preserves the original SPARQL query exactly as supplied for this GeoOutageBench entry.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?county ?sviRecord2000 ?svi2000 ?sviRecord2010 ?svi2010 ?sviRecord2022 ?svi2022 ?housingTransportationScore2022 ?populationChange2000To2022 ?povertyRate2022
WHERE {
  {
    SELECT ?county ?sviRecord2022 ?svi2022 ?housingTransportationScore2022 ?population2022 ?povertyRate2022
    WHERE {
      ?county a goo:County ;
              goo:locatedInState gokg:FloridaState .
      ?sviRecord2022 a goo:SVIRecord ;
                     goo:representsCounty ?county ;
                     goo:sviYear 2022 ;
                     goo:sviOverallScore ?svi2022 ;
                     goo:sviHousingTransportationTheme ?housingTransportationScore2022 ;
                     goo:totalPopulation ?population2022 ;
                     goo:povertyRate ?povertyRate2022 .
    }
    ORDER BY DESC(?housingTransportationScore2022)
    LIMIT 10
  }
  ?sviRecord2000 a goo:SVIRecord ;
                 goo:representsCounty ?county ;
                 goo:sviYear 2000 ;
                 goo:sviOverallScore ?svi2000 ;
                 goo:totalPopulation ?population2000 .
  ?sviRecord2010 a goo:SVIRecord ;
                 goo:representsCounty ?county ;
                 goo:sviYear 2010 ;
                 goo:sviOverallScore ?svi2010 .
  BIND((xsd:integer(?population2022) - xsd:integer(?population2000)) AS ?populationChange2000To2022)
}
ORDER BY DESC(?housingTransportationScore2022) ?county

# ------------------------------------------------------------------------------

# Query 62
# QID: 1000043
# Interpretation ID: Q1000043_I0
# Interpretation Type: primary interpretation
# Template ID: T009
# Template Family: hurricane_landfall_ranking_with_state_svi
# Question: Which Gulf Coast states have the highest number of hurricane landfalls in this century, and what is each state's average county-level SVI overall score?
# Question Template: Which {JURISDICTION_TYPE} have the highest number of {CYCLONE_EVENT_TYPE} landfalls across {TEMPORAL_SCOPE}, and what is each {JURISDICTION_TYPE}'s average {SVI_METRIC}?
# Label: Primary interpretation: Gulf Coast states with 2022 county-level SVI
# Ambiguity Dimensions: spatial, temporal, semantic
# Rationale: Operationalizes Gulf Coast states as a fixed five-state VALUES set, resolves this century as starting on 2001-01-01, and resolves the unspecified SVI year to 2022.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX geosparql:  <http://www.opengis.net/ont/geosparql#>
PREFIX geof:       <http://www.opengis.net/def/function/geosparql/>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?state ?hurricaneLandfallCount ?averageCountySviOverallScore
WHERE {
  VALUES ?state { gokg:TexasState gokg:LouisianaState gokg:MississippiState gokg:AlabamaState gokg:FloridaState }
  {
    SELECT ?state (COUNT(DISTINCT ?cyclone) AS ?hurricaneLandfallCount)
    WHERE {
      VALUES ?state { gokg:TexasState gokg:LouisianaState gokg:MississippiState gokg:AlabamaState gokg:FloridaState }
      ?state a goo:State ;
             geosparql:hasGeometry ?stateGeom .
      ?stateGeom geosparql:asWKT ?stateWKT .
      ?cyclone a goo:HurricaneEventRecord ;
               goo:eventStartTime ?stormStart ;
               goo:hasTrackRecord ?track .
      ?track a goo:HurricaneTrackRecord ;
             goo:status "HU"^^xsd:string ;
             goo:lat ?trackLat ;
             goo:lon ?trackLon .
      BIND(STRDT(CONCAT("POINT(", STR(?trackLon), " ", STR(?trackLat), ")"), geosparql:wktLiteral) AS ?trackPoint)
      FILTER (?stormStart >= "2001-01-01T00:00:00Z"^^xsd:dateTime)
      FILTER (geof:sfWithin(?trackPoint, ?stateWKT))
    }
    GROUP BY ?state
  }
  OPTIONAL {
    SELECT ?state (AVG(?sviScore) AS ?averageCountySviOverallScore)
    WHERE {
      VALUES ?state { gokg:TexasState gokg:LouisianaState gokg:MississippiState gokg:AlabamaState gokg:FloridaState }
      ?county a goo:County ;
              goo:locatedInState ?state .
      ?sviRecord a goo:SVIRecord ;
                 goo:representsCounty ?county ;
                 goo:sviYear 2022 ;
                 goo:sviOverallScore ?sviScore .
    }
    GROUP BY ?state
  }
}
ORDER BY DESC(?hurricaneLandfallCount) DESC(?averageCountySviOverallScore)
LIMIT 10

# ------------------------------------------------------------------------------

# Query 63
# QID: 1000043
# Interpretation ID: Q1000043_I1
# Interpretation Type: semantic interpretation
# Template ID: T009
# Template Family: hurricane_landfall_ranking_with_state_svi
# Question: Which Gulf Coast states have the highest number of hurricane landfalls in this century, and what is each state's average county-level SVI overall score?
# Question Template: Which {JURISDICTION_TYPE} have the highest number of {CYCLONE_EVENT_TYPE} landfalls across {TEMPORAL_SCOPE}, and what is each {JURISDICTION_TYPE}'s average {SVI_METRIC}?
# Label: Semantic interpretation: average across all available county-level SVI records
# Ambiguity Dimensions: semantic, temporal
# Rationale: The question does not name an SVI year, so this interpretation averages all available county-level SVI records instead of only 2022 records, while using 2001-01-01 as the start of this century.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX geosparql:  <http://www.opengis.net/ont/geosparql#>
PREFIX geof:       <http://www.opengis.net/def/function/geosparql/>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?state ?hurricaneLandfallCount ?averageCountySviOverallScore
WHERE {
  VALUES ?state { gokg:TexasState gokg:LouisianaState gokg:MississippiState gokg:AlabamaState gokg:FloridaState }
  {
    SELECT ?state (COUNT(DISTINCT ?cyclone) AS ?hurricaneLandfallCount)
    WHERE {
      VALUES ?state { gokg:TexasState gokg:LouisianaState gokg:MississippiState gokg:AlabamaState gokg:FloridaState }
      ?state a goo:State ;
             geosparql:hasGeometry ?stateGeom .
      ?stateGeom geosparql:asWKT ?stateWKT .
      ?cyclone a goo:HurricaneEventRecord ;
               goo:eventStartTime ?stormStart ;
               goo:hasTrackRecord ?track .
      ?track a goo:HurricaneTrackRecord ;
             goo:status "HU"^^xsd:string ;
             goo:lat ?trackLat ;
             goo:lon ?trackLon .
      BIND(STRDT(CONCAT("POINT(", STR(?trackLon), " ", STR(?trackLat), ")"), geosparql:wktLiteral) AS ?trackPoint)
      FILTER (?stormStart >= "2001-01-01T00:00:00Z"^^xsd:dateTime)
      FILTER (geof:sfWithin(?trackPoint, ?stateWKT))
    }
    GROUP BY ?state
  }
  OPTIONAL {
    SELECT ?state (AVG(?sviScore) AS ?averageCountySviOverallScore)
    WHERE {
      VALUES ?state { gokg:TexasState gokg:LouisianaState gokg:MississippiState gokg:AlabamaState gokg:FloridaState }
      ?county a goo:County ;
              goo:locatedInState ?state .
      ?sviRecord a goo:SVIRecord ;
                 goo:representsCounty ?county ;
                 goo:sviOverallScore ?sviScore .
    }
    GROUP BY ?state
  }
}
ORDER BY DESC(?hurricaneLandfallCount) DESC(?averageCountySviOverallScore)
LIMIT 10

