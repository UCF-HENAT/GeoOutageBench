# Interpretation Type: temporal-semantic interpretation
# Template ID: T010
# Template Family: event_sequence_svi_threshold
# Question: Which counties with high overall SVI scores had a Flood event occur after a Thunderstorm Wind event started within a few days in the same county, and what were the paired event times and SVI scores?
# Question Template: Which {JURISDICTION_TYPE} with {SVI_RELATIVE_LEVEL} {SVI_METRIC} had {SECOND_EVENT_TYPE} occur after {FIRST_EVENT_TYPE} started within {RELATIVE_SEQUENCE_WINDOW} in the same {SPATIAL_UNIT}, and what were the paired event times and {SVI_METRIC}?
# Label: Temporal-semantic interpretation: 2010 SVI >= 0.75 with Flood after Thunderstorm Wind start within 5 days
# Ambiguity Dimensions: temporal, semantic
# Rationale: Reflects the concrete Storm Events categories Thunderstorm Wind and Flood, with LIMIT 10, while using the alternate 2010 high-SVI and 5-day interpretation.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT DISTINCT ?county ?sviRecord ?sviYear ?sviScore ?thunderstormWindEvent ?thunderstormWindType ?thunderstormWindStart ?thunderstormWindEnd ?floodEvent ?floodType ?floodStart ?floodEnd
WHERE {
  ?county a goo:County .
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?county ;
             goo:sviYear ?sviYear ;
             goo:sviOverallScore ?sviScore .
  FILTER (?sviYear = 2010)
  FILTER (?sviScore >= 0.75)

  ?thunderstormWindEvent a goo:StormEventRecord ;
                         goo:occurredInCounty ?county ;
                         goo:stormEventType ?thunderstormWindType ;
                         goo:eventStartTime ?thunderstormWindStart ;
                         goo:eventEndTime ?thunderstormWindEnd .
  FILTER (REGEX(STR(?thunderstormWindType), "Thunderstorm Wind", "i"))

  ?floodEvent a goo:StormEventRecord ;
              goo:occurredInCounty ?county ;
              goo:stormEventType ?floodType ;
              goo:eventStartTime ?floodStart ;
              goo:eventEndTime ?floodEnd .
  FILTER (REGEX(STR(?floodType), "Flood", "i"))

  FILTER (?thunderstormWindStart <= ?floodStart)
  FILTER ((?floodStart - ?thunderstormWindStart) <= "P5D"^^xsd:dayTimeDuration)
}
ORDER BY DESC(?sviScore) ?county ?thunderstormWindStart ?floodStart
LIMIT 10

# ------------------------------------------------------------------------------

# Query 68
# QID: 1000046
# Interpretation ID: Q1000046_I0
# Interpretation Type: primary interpretation
# Template ID: T010
# Template Family: event_sequence_svi_threshold
# Question: Which counties with high housing and transportation SVI theme scores had a Flash Flood event occur after a Hail event started within about half a day in the same county, and what were the paired event times and SVI theme scores?
# Question Template: Which {JURISDICTION_TYPE} with {SVI_RELATIVE_LEVEL} {SVI_METRIC} had {SECOND_EVENT_TYPE} occur after {FIRST_EVENT_TYPE} started within {RELATIVE_SEQUENCE_WINDOW} in the same {SPATIAL_UNIT}, and what were the paired event times and {SVI_METRIC}?
# Label: Primary interpretation: 2020 housing and transportation SVI theme >= 0.85 with Flash Flood after Hail start within 12 hours
# Ambiguity Dimensions: temporal, semantic, spatiotemporal
# Rationale: Uses a distinct T010 event pair and SVI theme from the preceding T010 entry while keeping the same-county sequence structure.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT DISTINCT ?county ?sviRecord ?sviYear ?housingTransportationScore ?hailEvent ?hailType ?hailStart ?hailEnd ?flashFloodEvent ?flashFloodType ?flashFloodStart ?flashFloodEnd
WHERE {
  ?county a goo:County .
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?county ;
             goo:sviYear ?sviYear ;
             goo:sviHousingTransportationTheme ?housingTransportationScore .
  FILTER (?sviYear = 2020)
  FILTER (?housingTransportationScore >= 0.85)

  ?hailEvent a goo:StormEventRecord ;
             goo:occurredInCounty ?county ;
             goo:stormEventType ?hailType ;
             goo:eventStartTime ?hailStart ;
             goo:eventEndTime ?hailEnd .
  FILTER (REGEX(STR(?hailType), "Hail", "i"))

  ?flashFloodEvent a goo:StormEventRecord ;
                   goo:occurredInCounty ?county ;
                   goo:stormEventType ?flashFloodType ;
                   goo:eventStartTime ?flashFloodStart ;
                   goo:eventEndTime ?flashFloodEnd .
  FILTER (REGEX(STR(?flashFloodType), "Flash Flood", "i"))

  FILTER (?hailStart <= ?flashFloodStart)
  FILTER ((?flashFloodStart - ?hailStart) <= "PT12H"^^xsd:dayTimeDuration)
}
ORDER BY DESC(?housingTransportationScore) ?county ?hailStart ?flashFloodStart
LIMIT 10

# ------------------------------------------------------------------------------

# Query 69
# QID: 1000046
# Interpretation ID: Q1000046_I1
# Interpretation Type: temporal-semantic interpretation
# Template ID: T010
# Template Family: event_sequence_svi_threshold
# Question: Which counties with high housing and transportation SVI theme scores had a Flash Flood event occur after a Hail event started within about half a day in the same county, and what were the paired event times and SVI theme scores?
# Question Template: Which {JURISDICTION_TYPE} with {SVI_RELATIVE_LEVEL} {SVI_METRIC} had {SECOND_EVENT_TYPE} occur after {FIRST_EVENT_TYPE} started within {RELATIVE_SEQUENCE_WINDOW} in the same {SPATIAL_UNIT}, and what were the paired event times and {SVI_METRIC}?
# Label: Temporal-semantic interpretation: 2022 housing and transportation SVI theme >= 0.8 with Flash Flood after Hail start within 1 day
# Ambiguity Dimensions: temporal, semantic
# Rationale: Keeps the Hail-to-Flash-Flood sequence but broadens the ambiguous half-day window and uses the newer SVI year with a slightly lower high-SVI threshold.
PREFIX goo:        <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:       <http://example.org/resource#>
PREFIX xsd:        <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
SELECT DISTINCT ?county ?sviRecord ?sviYear ?housingTransportationScore ?hailEvent ?hailType ?hailStart ?hailEnd ?flashFloodEvent ?flashFloodType ?flashFloodStart ?flashFloodEnd
WHERE {
  ?county a goo:County .
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?county ;
             goo:sviYear ?sviYear ;
             goo:sviHousingTransportationTheme ?housingTransportationScore .
  FILTER (?sviYear = 2022)
  FILTER (?housingTransportationScore >= 0.8)

  ?hailEvent a goo:StormEventRecord ;
             goo:occurredInCounty ?county ;
             goo:stormEventType ?hailType ;
             goo:eventStartTime ?hailStart ;
             goo:eventEndTime ?hailEnd .
  FILTER (REGEX(STR(?hailType), "Hail", "i"))

  ?flashFloodEvent a goo:StormEventRecord ;
                   goo:occurredInCounty ?county ;
                   goo:stormEventType ?flashFloodType ;
                   goo:eventStartTime ?flashFloodStart ;
                   goo:eventEndTime ?flashFloodEnd .
  FILTER (REGEX(STR(?flashFloodType), "Flash Flood", "i"))

  FILTER (?hailStart <= ?flashFloodStart)
  FILTER ((?flashFloodStart - ?hailStart) <= "P1D"^^xsd:dayTimeDuration)
}
ORDER BY DESC(?housingTransportationScore) ?county ?hailStart ?flashFloodStart
LIMIT 10

# ------------------------------------------------------------------------------

# Query 70
# QID: 1000047
# Interpretation ID: Q1000047_I0
# Interpretation Type: original source query
# Template ID: T007
# Template Family: storm_event_svi_county_threshold
# Question: Which counties in the hurricane-prone state had high socioeconomic vulnerability in a recent year and a dozen or so wind-related storm events recorded that same year?
# Question Template: Which counties in {STATE_DESCRIPTOR} had {SVI_DESCRIPTOR} in {RELATIVE_YEAR_DESCRIPTOR} and a number of {EVENT_TYPE} recorded that same year?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatial, temporal, semantic, spatiotemporal
# Rationale: Resolves the ambiguous state, year, vulnerability level, and wind-related event count to one T007 interpretation where same-county and same-year storm event counts co-occur with a county-level SVI threshold.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?county ?sviRecord ?socioeconomicScore ?thunderstormWindEventCount
WHERE {
  ?county a goo:County ;
          goo:locatedInState gokg:FloridaState .
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?county ;
             goo:sviYear 2022 ;
             goo:sviSocioeconomicTheme ?socioeconomicScore .
  FILTER (?socioeconomicScore >= 0.75)
  {
    SELECT ?county (COUNT(DISTINCT ?event) AS ?thunderstormWindEventCount)
    WHERE {
      ?event a goo:StormEventRecord ;
             goo:occurredInState gokg:FloridaState ;
             goo:occurredInCounty ?county ;
             goo:stormEventType ?eventType ;
             goo:eventStartTime ?eventStart .
      FILTER (YEAR(?eventStart) = 2022)
      FILTER (REGEX(STR(?eventType), "Thunderstorm Wind", "i"))
    }
    GROUP BY ?county
  }
  FILTER (?thunderstormWindEventCount >= 12)
}
ORDER BY DESC(?socioeconomicScore) DESC(?thunderstormWindEventCount) ?county
LIMIT 10

# ------------------------------------------------------------------------------

# Query 71
# QID: 1000047
# Interpretation ID: Q1000047_I1
# Interpretation Type: spatiotemporal-semantic interpretation
# Template ID: T007
# Template Family: storm_event_svi_county_threshold
# Question: Which counties in the hurricane-prone state had high socioeconomic vulnerability in a recent year and a dozen or so wind-related storm events recorded that same year?
# Question Template: Which counties in {STATE_DESCRIPTOR} had {SVI_DESCRIPTOR} in {RELATIVE_YEAR_DESCRIPTOR} and a number of {EVENT_TYPE} recorded that same year?
# Label: Alternate spatiotemporal-semantic interpretation: Texas, 2020, socioeconomic SVI >= 0.8, any Wind event type
# Ambiguity Dimensions: spatial, temporal, semantic, spatiotemporal
# Rationale: Uses only the ambiguous wording in the question to choose a different hurricane-prone state, recent year, high-vulnerability threshold, and wind-related event interpretation while preserving the same county-year co-occurrence structure.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?county ?sviRecord ?socioeconomicScore ?windEventCount
WHERE {
  ?county a goo:County ;
          goo:locatedInState gokg:TexasState .
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?county ;
             goo:sviYear 2020 ;
             goo:sviSocioeconomicTheme ?socioeconomicScore .
  FILTER (?socioeconomicScore >= 0.8)
  {
    SELECT ?county (COUNT(DISTINCT ?event) AS ?windEventCount)
    WHERE {
      ?event a goo:StormEventRecord ;
             goo:occurredInState gokg:TexasState ;
             goo:occurredInCounty ?county ;
             goo:stormEventType ?eventType ;
             goo:eventStartTime ?eventStart .
      FILTER (YEAR(?eventStart) = 2020)
      FILTER (REGEX(STR(?eventType), "Wind", "i"))
    }
    GROUP BY ?county
  }
  FILTER (?windEventCount >= 12)
}
ORDER BY DESC(?socioeconomicScore) DESC(?windEventCount) ?county
LIMIT 10

# ------------------------------------------------------------------------------

# Query 72
# QID: 1000047
# Interpretation ID: Q1000047_I2
# Interpretation Type: spatiotemporal-semantic interpretation
# Template ID: T007
# Template Family: storm_event_svi_county_threshold
# Question: Which counties in the hurricane-prone state had high socioeconomic vulnerability in a recent year and a dozen or so wind-related storm events recorded that same year?
# Question Template: Which counties in {STATE_DESCRIPTOR} had {SVI_DESCRIPTOR} in {RELATIVE_YEAR_DESCRIPTOR} and a number of {EVENT_TYPE} recorded that same year?
# Label: Alternate spatiotemporal-semantic interpretation: Louisiana, 2018, socioeconomic SVI >= 0.85, High Wind or Strong Wind count between 10 and 14
# Ambiguity Dimensions: spatial, temporal, semantic, spatiotemporal
# Rationale: Uses only the ambiguous wording in the question to choose a third hurricane-prone state, recent year, high-vulnerability threshold, and wind-related event interpretation while preserving the same county-year co-occurrence structure.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?county ?sviRecord ?socioeconomicScore ?coastalWindEventCount
WHERE {
  ?county a goo:County ;
          goo:locatedInState gokg:LouisianaState .
  ?sviRecord a goo:SVIRecord ;
             goo:representsCounty ?county ;
             goo:sviYear 2018 ;
             goo:sviSocioeconomicTheme ?socioeconomicScore .
  FILTER (?socioeconomicScore >= 0.85)
  {
    SELECT ?county (COUNT(DISTINCT ?event) AS ?coastalWindEventCount)
    WHERE {
      ?event a goo:StormEventRecord ;
             goo:occurredInState gokg:LouisianaState ;
             goo:occurredInCounty ?county ;
             goo:stormEventType ?eventType ;
             goo:eventStartTime ?eventStart .
      FILTER (YEAR(?eventStart) = 2018)
      FILTER (REGEX(STR(?eventType), "Wind", "i"))
    }
    GROUP BY ?county
  }
  FILTER (?coastalWindEventCount >= 10 && ?coastalWindEventCount <= 14)
}
ORDER BY DESC(?socioeconomicScore) DESC(?coastalWindEventCount) ?county
LIMIT 10
