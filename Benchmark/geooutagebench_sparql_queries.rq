# Query 12
# QID: 1000009
# Interpretation ID: Q1000009_I0
# Interpretation Type: original source query
# Template ID: T004
# Template Family: multimodal_correspondence
# Question: Which nighttime-light scene corresponds to the customer outage record for the Florida county with the seat in Bronson, on August 15, 2017 at 20:15?
# Question Template: Which {IMAGE_TYPE} scene corresponds to {OUTAGE_RECORD} under {SPATIOTEMPORAL_ALIGNMENT}?
# Label: Original exact KG interpretation from source JSON
# Ambiguity Dimensions: spatiotemporal
# Rationale: Preserves the original SPARQL query exactly as supplied in the source GeoOutageBench JSON.
PREFIX goo:    <https://ucf-henat.github.io/GeoOutageOnto/#>
PREFIX gokg:   <http://example.org/resource#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?ntl
WHERE {
  VALUES ?rec { gokg:customeroutagerecord.12075.2017-08-15T20-15-00Z }
  ?rec a goo:CustomerOutageRecord ;
       goo:representsCounty ?county ;
       goo:recordDateTime ?recordDate .
  ?ntl a goo:NTLImage ;
       goo:representsCounty ?county ;
       goo:acquisitionDateTime ?imageDate .
  FILTER (SUBSTR(STR(?recordDate), 1, 10) = SUBSTR(STR(?imageDate), 1, 10))
}
LIMIT 10

